APP_ENV=development
PORT=8080
PATH_MIGRATE=migrations/000001_init.sql
CORS_ALLOWED_ORIGINS=*

# Redis cache. Location cache TTL supports duration strings or numeric seconds.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
LOCATION_CACHE_TTL=4320h

# Optional command override: serve, migrate, or import.
COMMAND=serve

# Seed data on first run when raw_locations is empty.
AUTO_SEED=true
AUTO_SEED_REQUIRED=false
SEED_FILE=data/wilayah.sql

# Prefer DATABASE_URL in production.
DATABASE_URL=postgres://location:location@localhost:5438/location?sslmode=disable

# Optional if DATABASE_URL is empty.
DB_HOST=localhost
DB_PORT=5438
DB_USERNAME=location
DB_PASS=location
DB_NAME=location
DB_SSLMODE=disable

# Docker entrypoint options.
RUN_MIGRATION=false
RUN_IMPORT=false
IMPORT_FILE=/app/data/wilayah.sql
